{
  "name": "targetgoals-tasks",
  "private": true,
  "version": "0.1.0",
  "description": "TargetGoals Tasks — local-first tasks with recurring daily tasks, streaks, and a completion overview. Monorepo: shared core + web (and, later, server + Android app).",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "postinstall": "npm run build -w @targetgoals/shared",
    "dev": "npm run dev -w @targetgoals/web",
    "dev:mobile": "npm run start -w @targetgoals/mobile",
    "dev:server": "npm run dev -w @targetgoals/server",
    "start:server": "npm run start -w @targetgoals/server",
    "build": "npm run build -w @targetgoals/web",
    "build:shared": "npm run build -w @targetgoals/shared",
    "test": "npm run test -w @targetgoals/shared",
    "typecheck:server": "npm run typecheck -w @targetgoals/server",
    "preview": "npm run preview -w @targetgoals/web"
  }
}
