# Copy to .env and adjust. The real .env is git-ignored.

# Port the server listens on.
PORT=4000

# Public base URL clients should call. For phone pairing, set this to your
# Tailscale URL — ideally the HTTPS one from `tailscale serve`, e.g.
#   PUBLIC_URL=https://your-pc.tailnet-name.ts.net
# Left as localhost, only this computer can reach it.
PUBLIC_URL=http://localhost:4000

# Friendly name shown on the pairing page and in the app.
SERVER_NAME=TargetGoals Tasks

# Where the database + config (incl. the auth token) are stored.
# Defaults to apps/server/data. Keep this directory out of git.
# DATA_DIR=./data
