{
  "expo": {
    "name": "TargetGoals Tasks",
    "slug": "targetgoals-tasks",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "targetgoals",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0b1220",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b1220"
    },
    "runtimeVersion": { "policy": "appVersion" },
    "updates": {
      "url": "https://u.expo.dev/6f90eccc-4125-4230-b256-9efe5cdab72f"
    },
    "android": {
      "package": "com.targetgoals.tasks",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow TargetGoals Tasks to use the camera to scan your server's pairing QR code."
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "TargetGoalsDaily",
              "label": "TargetGoals Daily",
              "minWidth": "180dp",
              "minHeight": "110dp",
              "targetCellWidth": 3,
              "targetCellHeight": 2,
              "description": "Today's habits, streak, and progress",
              "updatePeriodMillis": 1800000,
              "resizeMode": "horizontal|vertical"
            }
          ]
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "6f90eccc-4125-4230-b256-9efe5cdab72f"
      },
      "appVersion": "0.1.1"
    },
    "owner": "deveevee"
  }
}
