{
  "name": "@targetgoals/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared types and pure logic (dates, streak/heatmap stats) for TargetGoals Tasks.",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "clean": "tsc -b --clean",
    "test": "node --import tsx --test src/*.test.ts"
  },
  "devDependencies": {
    "tsx": "^4.22.4"
  }
}
